{
  "name": "skycrypt-frontend",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyCryptWebsite/SkyCryptv2.git"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "dotenv -e .env.development -- vite build",
    "preview": "vite preview",
    "preview:dev": "dotenv -e .env.development -- vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "runbuild": "node ./build",
    "test": "vitest --ui && pnpm run test:unit -- --run",
    "test:ui": "pnpm run test:unit -- --ui",
    "lint": "prettier --check . && eslint . && pnpm check",
    "format": "prettier --write .",
    "prepare": "svelte-kit sync || echo ''",
    "postinstall": "simple-git-hooks",
    "test:unit": "vitest",
    "changelog": "changelogen",
    "changelog:bump": "changelogen --bump",
    "release": "changelogen --release --push"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@commitlint/types": "^20.2.0",
    "@date-fns/tz": "^1.4.1",
    "@eslint/compat": "^2.0.0",
    "@eslint/js": "^9.39.2",
    "@lucide/svelte": "^0.562.0",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/kit": "^2.49.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.0.3",
    "@types/relaxed-json": "^1.0.4",
    "@types/upng-js": "^2.1.5",
    "@vitest/browser-webdriverio": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "bits-ui": "^2.14.4",
    "changelogen": "^0.6.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.1",
    "formsnap": "^2.0.1",
    "globals": "^17.0.0",
    "ky": "^1.14.2",
    "numerable": "^0.3.15",
    "orval": "^7.17.2",
    "paneforge": "^1.0.2",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "pretty-ms": "^9.3.0",
    "runed": "^0.37.1",
    "skinview3d": "^3.4.1",
    "svelte": "^5.46.1",
    "svelte-check": "^4.3.5",
    "svelte-dnd-action": "^0.9.69",
    "svelte-interactions": "^0.2.0",
    "svelte-persisted-store": "^0.12.0",
    "svelte-preprocess": "^6.0.3",
    "svelte-seo": "2.0.0",
    "svelte-sonner": "^1.0.7",
    "svelte-tiny-virtual-list": "4.0.0-rc.2",
    "sveltekit-superforms": "^2.29.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "npm:rolldown-vite@^7.3.0",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^4.0.16",
    "vitest-browser-svelte": "^2.0.1",
    "webdriverio": "^9.22.0",
    "zod": "^4.3.4"
  },
  "dependencies": {
    "@sentry/sveltekit": "^10.32.1",
    "simple-git-hooks": "^2.13.1"
  },
  "engines": {
    "node": "^24",
    "pnpm": "^10",
    "deno": "forbidden, use node instead",
    "npm": "forbidden, use pnpm instead",
    "yarn": "forbidden, use pnpm instead",
    "bun": "forbidden, use pnpm instead"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@tailwindcss/oxide",
      "edgedriver",
      "esbuild",
      "geckodriver",
      "simple-git-hooks",
      "svelte-preprocess"
    ],
    "overrides": {
      "vite": "npm:rolldown-vite@^7.3.0"
    }
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm exec commitlint --edit $1"
  }
}
